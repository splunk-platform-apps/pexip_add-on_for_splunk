                "target": "3rdparty/windows_x86_64/python39",
                "dependencies": true,
                "os": "windows"
            },
            {
                "name": "cryptography",
                "version": "43.0.3",
                "platform": "manylinux2014_x86_64",
                "python_version": "39",
                "target": "3rdparty/linux_x86_64/python39",
                "dependencies": true,
                "os": "linux"
            },
            {
                "name": "cryptography",
                "version": "43.0.3",
                "platform": "macosx_10_12_x86_64",
                "python_version": "39",
                "target": "3rdparty/darwin_x86_64/python39",
                "dependencies": true,
                "os": "darwin"
            }
        ]
    },
    "options": {
        "restHandlers": [
            {
                "name": "dropdown_alarm_names",
                "endpoint": "dropdown_alarm_names",
