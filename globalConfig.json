{
    "pages": {
        "configuration": {
            "tabs": [
                {
                    "name": "account",
                    "table": {
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ],
                        "header": [
                            {
                                "label": "Name",
                                "field": "name"
                            }
                        ]
                    },
                    "entity": [
                        {
                            "type": "text",
                            "label": "Name",
                            "validators": [
                                {
                                    "type": "regex",
                                    "errorMsg": "Account Name must begin with a letter and consist exclusively of alphanumeric characters and underscores.",
                                    "pattern": "^[a-zA-Z]\\w*$"
                                },
                                {
                                    "type": "string",
                                    "errorMsg": "Length of input name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ],
                            "field": "name",
                            "help": "A unique name for the account.",
                            "required": true
                        },
                        {
                            "type": "text",
                            "label": "Hostname",
                            "field": "hostname",
                            "help": "Pexip Hostname (e.g. mydomain.pexip).",
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Length of hostname should be between 1 and 8192",
                                    "minLength": 1,
                                    "maxLength": 8192
                                }
                            ],
                            "required": true
                        },
                        {
                            "field": "authentication",
                            "label": "Authentication Type",
                            "help": "Select the type of authentication to be used",
                            "required": true,
                            "type": "singleSelect",
                            "options": {
                                "disableSearch": true,
                                "autoCompleteFields": [
                                    {
                                        "value": "basic",
                                        "label": "Basic HTTP"
                                    },
                                    {
                                        "value": "oauth",
                                        "label": "OAuth2"
                                    }
                                ]
                            },
                            "defaultValue": "oauth",
                            "modifyFieldsOnValue": [
                                {
                                    "fieldValue": "basic",
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "username",
                                            "display": true,
                                            "required": true
                                        },
                                        {
                                            "fieldId": "password",
                                            "display": true,
                                            "required": true
                                        },
                                        {
                                            "fieldId": "client_id_oauth_credentials",
                                            "display": false,
                                            "required": false
                                        },
                                        {
                                            "fieldId": "client_secret_oauth_credentials",
                                            "display": false,
                                            "required": false
                                        },
                                        {
                                            "fieldId": "endpoint_token_oauth_credentials",
                                            "display": false,
                                            "required": false
                                        }
                                    ]
                                },
                                {
                                    "fieldValue": "oauth",
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "username",
                                            "display": false,
                                            "required": false
                                        },
                                        {
                                            "fieldId": "password",
                                            "display": false,
                                            "required": false
                                        },
                                        {
                                            "fieldId": "client_id_oauth_credentials",
                                            "display": true,
                                            "required": true
                                        },
                                        {
                                            "fieldId": "client_secret_oauth_credentials",
                                            "display": true,
                                            "required": true
                                        },
                                        {
                                            "fieldId": "endpoint_token_oauth_credentials",
                                            "display": true,
                                            "required": true
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "field": "username",
                            "label": "Username",
                            "type": "text",
                            "required": false,
                            "help": "Username used to authenticate at Pexip.",
                            "defaultValue": "",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 200,
                                    "errorMsg": "Max length of text input is 200"
                                }
                            ]
                        },
                        {
                            "field": "password",
                            "label": "Password",
                            "type": "text",
                            "encrypted": true,
                            "required": false,
                            "help": "Password used to authenticate at Pexip.",
                            "defaultValue": "",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of password is 8192"
                                }
                            ]
                        },
                        {
                            "field": "client_id_oauth_credentials",
                            "label": "Client Id",
                            "type": "text",
                            "required": true,
                            "help": "Enter the Pexip Client Id.",
                            "defaultValue": "",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 200,
                                    "errorMsg": "Max length of text input is 200"
                                }
                            ]
                        },
                        {
                            "field": "client_secret_oauth_credentials",
                            "label": "Client Secret",
                            "type": "text",
                            "encrypted": true,
                            "required": true,
                            "help": "Enter the Pexip Client Secret.",
                            "defaultValue": ""
                        },
                        {
                            "field": "endpoint_token_oauth_credentials",
                            "label": "Endpoint",
                            "type": "text",
                            "required": true,
                            "help": "Enter the domain name used for the token acquisition. Example: yourdomain.login.pexip.com",
                            "defaultValue": ""
                        }
                    ],
                    "title": "Accounts"
                },
                {
                    "type": "loggingTab"
                },
                {
                    "type": "proxyTab"
                }
            ],
            "title": "Configuration",
            "description": "Set up your add-on"
        },
        "inputs": {
            "services": [
                {
                    "name": "conference",
                    "entity": [
                        {
                            "type": "text",
                            "label": "Name",
                            "validators": [
                                {
                                    "type": "regex",
                                    "errorMsg": "Input Name must begin with a letter and consist exclusively of alphanumeric characters and underscores.",
                                    "pattern": "^[a-zA-Z]\\w*$"
                                },
                                {
                                    "type": "string",
                                    "errorMsg": "Length of input name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ],
                            "field": "name",
                            "help": "A unique name for the data input.",
                            "required": true
                        },
                        {
                            "type": "interval",
                            "label": "Interval",
                            "defaultValue": "300",
                            "field": "interval",
                            "options": {
                                "range": [
                                    10,
                                    999999999
                                ]
                            },
                            "help": "Time interval of the data input, in seconds.",
                            "required": true
                        },
                        {
                            "type": "index",
                            "field": "index",
                            "label": "Index"
                        },
                        {
                            "type": "singleSelect",
                            "label": "Account to use",
                            "options": {
                                "referenceName": "account"
                            },
                            "help": "Account to use for this input.",
                            "field": "account",
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Length of account name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ]
                        },
                        {
                            "type": "multipleSelect",
                            "field": "service_types",
                            "label": "Service Type(s)",
                            "help": "The conference service type(s) to filter data to index. Set to 'All' to disable filtering.",
                            "required": true,
                            "defaultValue": "*",
                            "options": {
                                "delimiter": "|",
                                "items": [
                                    {
                                        "value": "*",
                                        "label": "All"
                                    },
                                    {
                                        "value": "conference",
                                        "label": "Virtual Meeting Room"
                                    },
                                    {
                                        "value": "ivr",
                                        "label": "Virtual Reception IVR"
                                    },
                                    {
                                        "value": "waiting_room",
                                        "label": "Waiting Room"
                                    },
                                    {
                                        "value": "insufficient_capacity_screen",
                                        "label": "Insuffienct Capacity Screen"
                                    },
                                    {
                                        "value": "insufficient_licenses_screen",
                                        "label": "Insufficient Licenses Screen"
                                    },
                                    {
                                        "value": "invalid_license_screen",
                                        "label": "Invalid License Screen"
                                    },
                                    {
                                        "value": "presentation",
                                        "label": "Presentation"
                                    },
                                    {
                                        "value": "two_stage_dialing",
                                        "label": "Two Stage Dialing"
                                    },
                                    {
                                        "value": "gateway",
                                        "label": "Distributed Gateway"
                                    },
                                    {
                                        "value": "lecture",
                                        "label": "Lecture"
                                    },
                                    {
                                        "value": "test_call",
                                        "label": "Test Call"
                                    }
                                ]
                            }
                        },
                        {
                            "type": "checkbox",
                            "label": "Historical data",
                            "field": "historical_data_enabled",
                            "help": "Select to index data about conferences that are no longer in progress. Unselect to index data about currently in progress conferences.",
                            "required": true,
                            "defaultValue": true,
                            "modifyFieldsOnValue": [
                                {
                                    "fieldValue": 1,
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "service_name",
                                            "display": true
                                        },
                                        {
                                            "fieldId": "duration",
                                            "display": true
                                        }
                                    ]
                                },
                                {
                                    "fieldValue": 0,
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "service_name",
                                            "display": false
                                        },
                                        {
                                            "fieldId": "duration",
                                            "display": false
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "field": "service_name",
                            "label": "Service Name",
                            "required": false,
                            "help": "The name used to refer to the service. Enter a value to index data filtered based on service name.",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 250,
                                    "errorMsg": "Max length of Service Name is 250"
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Duration",
                            "field": "duration",
                            "required": false,
                            "help": "The duration of the conference in seconds. Enter a value to index data filtered based on conference duration.",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        65535
                                    ],
                                    "isInteger": true
                                }
                            ]
                        }
                    ],
                    "inputHelperModule": "conference_helper",
                    "title": "Conference"
                },
                {
                    "name": "participants",
                    "entity": [
                        {
                            "type": "text",
                            "label": "Name",
                            "validators": [
                                {
                                    "type": "regex",
                                    "errorMsg": "Input Name must begin with a letter and consist exclusively of alphanumeric characters and underscores.",
                                    "pattern": "^[a-zA-Z]\\w*$"
                                },
                                {
                                    "type": "string",
                                    "errorMsg": "Length of input name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ],
                            "field": "name",
                            "help": "A unique name for the data input.",
                            "required": true
                        },
                        {
                            "type": "interval",
                            "label": "Interval",
                            "defaultValue": "300",
                            "field": "interval",
                            "options": {
                                "range": [
                                    10,
                                    999999999
                                ]
                            },
                            "help": "Time interval of the data input, in seconds.",
                            "required": true
                        },
                        {
                            "type": "index",
                            "field": "index",
                            "label": "Index"
                        },
                        {
                            "type": "singleSelect",
                            "label": "Account to use",
                            "options": {
                                "referenceName": "account"
                            },
                            "help": "Account to use for this input.",
                            "field": "account",
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Length of account name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ]
                        },
                        {
                            "type": "multipleSelect",
                            "field": "call_directions",
                            "label": "Call Direction(s)",
                            "help": "The direction(s) of the ended calls to filter data to index.",
                            "required": true,
                            "defaultValue": "in|out",
                            "options": {
                                "delimiter": "|",
                                "items": [
                                    {
                                        "value": "in",
                                        "label": "Incoming"
                                    },
                                    {
                                        "value": "out",
                                        "label": "Outgoing"
                                    }
                                ]
                            }
                        },
                        {
                            "type": "text",
                            "label": "Duration",
                            "field": "duration",
                            "required": false,
                            "help": "The duration of the ended calls in seconds. Enter a value to index data filtered based on this duration.",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        65535
                                    ],
                                    "isInteger": true
                                }
                            ]
                        }
                    ],
                    "inputHelperModule": "participants_helper",
                    "title": "Participants"
                },
                {
                    "name": "alarms",
                    "entity": [
                        {
                            "type": "text",
                            "label": "Name",
                            "validators": [
                                {
                                    "type": "regex",
                                    "errorMsg": "Input Name must begin with a letter and consist exclusively of alphanumeric characters and underscores.",
                                    "pattern": "^[a-zA-Z]\\w*$"
                                },
                                {
                                    "type": "string",
                                    "errorMsg": "Length of input name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ],
                            "field": "name",
                            "help": "A unique name for the data input.",
                            "required": true
                        },
                        {
                            "type": "interval",
                            "label": "Interval",
                            "defaultValue": "300",
                            "field": "interval",
                            "options": {
                                "range": [
                                    10,
                                    999999999
                                ]
                            },
                            "help": "Time interval of the data input, in seconds.",
                            "required": true
                        },
                        {
                            "type": "index",
                            "field": "index",
                            "label": "Index"
                        },
                        {
                            "type": "singleSelect",
                            "label": "Account to use",
                            "options": {
                                "referenceName": "account"
                            },
                            "help": "Account to use for this input.",
                            "field": "account",
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "errorMsg": "Length of account name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ]
                        },
                        {
                            "type": "multipleSelect",
                            "field": "alarm_level",
                            "label": "Alarm Level",
                            "help": "The severity level of this alarm. Leave empty to get all levels.",
                            "required": false,
                            "defaultValue": "critical|error",
                            "options": {
                                "delimiter": "|",
                                "items": [
                                    {
                                        "value": "critical",
                                        "label": "Critical"
                                    },
                                    {
                                        "value": "error",
                                        "label": "Error"
                                    },
                                    {
                                        "value": "warning",
                                        "label": "Warning"
                                    },
                                    {
                                        "value": "info",
                                        "label": "Info"
                                    }
                                ]
                            }
                        },
                        {
                            "field": "alarm_names",
                            "label": "Alarm Name(s)",
                            "type": "multipleSelect",
                            "help": "Please provide to filter data based on alarms name. Leave empty to get all.",
                            "required": false,
                            "options": {
                                "createSearchChoice": true,
                                "delimiter": "|",
                                "endpointUrl": "pexip_addon_for_splunk/dropdown_alarm_names"
                            }
                        }
                    ],
                    "inputHelperModule": "alarms_helper",
                    "title": "Alarms"
                }
            ],
            "title": "Inputs",
            "description": "Manage your data inputs",
            "table": {
                "actions": [
                    "edit",
