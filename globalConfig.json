    "meta": {
        "name": "pexip_addon_for_splunk",
        "restRoot": "pexip_addon_for_splunk",
        "version": "0.0.1",
        "displayName": "Pexip Add-on for Splunk",
        "schemaVersion": "0.0.10",
        "supportedThemes": [
            "light",
            "dark"
        ],
        "defaultView": "inputs",
        "os-dependentLibraries": [
            {
                "name": "cryptography",
                "version": "43.0.3",
